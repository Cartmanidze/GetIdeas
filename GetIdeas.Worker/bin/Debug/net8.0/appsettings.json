{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "GetIdeas.Worker": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Reddit": {
    "ClientId": "",
    "ClientSecret": "",
    "UserAgent": "windows:getideas:v1.0.0 (by /u/your_reddit_username)",
    "Subreddits": [
      "Lightbulb",
      "SomebodyMakeThis",
      "startup",
      "SaaS",
      "Entrepreneur",
      "smallbusiness",
      "productivity"
    ],
    "Keywords": [
      "I wish there was a tool",
      "How do you automate",
      "Is there an app for",
      "I hate doing this manually"
    ],
    "MaxPostsPerSubreddit": 75,
    "LookbackHours": 24
  },
  "Processing": {
    "PollIntervalMinutes": 360,
    "MinWordCount": 20,
    "RequireKeywordMatch": false,
    "MinimumConfidenceToNotify": 6,
    "StopPhrases": [
      "[removed]",
      "[deleted]"
    ]
  },
  "Llm": {
    "ApiKey": "",
    "Model": "gpt-4o-mini",
    "Endpoint": "https://api.openai.com/v1/chat/completions",
    "TimeoutSeconds": 60
  },
  "Storage": {
    "ConnectionString": "Data Source=getideas.db"
  },
  "Telegram": {
    "Enabled": false,
    "BotToken": "",
    "ChatId": ""
  }
}
